DISCORD_TOKEN=
DB_HOST=localhost
DB_PORT=3306
DB_USER=rnguser
DB_PASSWORD=
DB_NAME=rngstreet_test
SCAN_CRON=0 3 * * *
TIMEZONE=Pacific/Auckland
RUNELITE_ACCOUNT_TYPE=STANDARD
HTTP_USER_AGENT=RNG-CA-Bot/1.0
LOG_LEVEL=INFO
LOG_FILE=logs/rng_ca_bot.log
REWARD_KEYS_REQUIRE_VERIFICATION=true
REWARD_ADMIN_API_KEY=
# Relative task selection weights by tier.
# Higher number = more likely within the eligible pool after other filters.
# Set every tier if you want full control, or override just the ones you care about.
TIER_ASSIGNMENT_WEIGHTS=easy=6,medium=5,hard=4,elite=3,master=2,grandmaster=1

# Required for one persistent global task message with buttons.
# DISCORD_TASK_PANEL_CHANNEL_ID=123456789012345678

# Optional persistent highscores panel channel.
# DISCORD_HIGHSCORES_CHANNEL_ID=123456789012345678

# Reward payouts are accessed via /admin -> Payout Board (no channel variable needed).

# Optional web URL used in Discord when issuing reward keys.
REWARD_WEB_URL=http://localhost:5173/

# Optional web URL used in Discord when issuing task-roll keys.
TASK_ROLL_WEB_URL=http://localhost:5173/?mode=task

# Required for automated daily scan list in v1.
# Must return one column: rsn (player names).
# Example:
# USER_SOURCE_SQL=SELECT rsn FROM players WHERE active = 1
USER_SOURCE_SQL=
